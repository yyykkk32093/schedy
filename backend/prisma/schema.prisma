model PlanMaster {
  id                  String    @id @map("id") // 'FREE' | 'LITE' | 'PRO' | 'LIFETIME'
  displayName         String    @map("display_name") // UI表示名
  description         String?   @map("description")
  monthlyPrice        Int?      @map("monthly_price") // 月額（円）。null = 無料 or 買い切り
  oneTimePrice        Int?      @map("one_time_price") // 買い切り価格（円）。LIFETIME のみ
  revenuecatProductId String?   @map("revenuecat_product_id") // RevenueCat の product_id
  sortOrder           Int       @default(0) @map("sort_order") // 表示順
  availableFrom       DateTime? @map("available_from") // 販売開始日（null = 制限なし）
  availableTo         DateTime? @map("available_to") // 販売終了日（null = 制限なし）

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([sortOrder])
  @@index([availableFrom, availableTo])

  @@map("plan_masters")
  @@schema("master")
}

// ============================================================
// W5-25: ChannelReadState（チャンネル既読状態）
// ============================================================

model ChannelReadState {
  id         String   @id @default(uuid()) @map("id")
  channelId  String   @map("channel_id")
  userId     String   @map("user_id")
  lastReadAt DateTime @default(now()) @map("last_read_at")

  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])

  @@map("channel_read_states")
  @@schema("messaging")
}

// ============================================================
// Wave6 Phase 8-B: Inquiry（問い合わせ）+ Phase 7 / 9b-01: HelpFeedback
// 詳細設計: projects/00_requirements/202603_07_bugfix-and-refactoring_wave6/phase8-progress.md
// ============================================================

/// 問い合わせカテゴリマスタ（Phase 7 のヘルプカテゴリと relatedHelpCategorySlug で紐付け）
model InquiryCategoryMaster {
  id                      String  @id @default(uuid()) @map("id")
  /// URL/参照用の一意キー（例: 'login_trouble', 'billing', 'general'）
  slug                    String  @unique @map("slug")
  /// i18n ラベル: { "ja": "ログイン・登録の不具合", "en": "Login / Sign-up issue" }
  labelI18n               Json    @map("label_i18n")
  /// Phase 7 ヘルプカテゴリの slug 参照（紐付けがない場合は null）
  relatedHelpCategorySlug String? @map("related_help_category_slug")
  sortOrder               Int     @default(0) @map("sort_order")
  isActive                Boolean @default(true) @map("is_active")
  /// 匿名ルート（/contact/anonymous）専用カテゴリかどうか
  /// true の場合、認証ルート (/contact) のカテゴリ選択肢に含めない
  isAnonymousOnly         Boolean @default(false) @map("is_anonymous_only")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  inquiries Inquiry[]

  @@index([isActive, sortOrder])

  @@map("inquiry_category_masters")
  @@schema("master")
}

/// 問い合わせスレッド本体
model Inquiry {
  id             String    @id @default(uuid()) @map("id")
  /// 認証ユーザー問い合わせの場合に設定。匿名問い合わせの場合 null
  userId         String?   @map("user_id")
  /// 匿名問い合わせ時の連絡先メール（運営返信先）。認証ユーザーの場合 null
  contactEmail   String?   @map("contact_email")
  categoryId     String    @map("category_id")
  title          String    @map("title") @db.VarChar(200)
  /// OPEN | IN_PROGRESS | RESOLVED | CLOSED
  status         String    @default("OPEN") @map("status")
  /// マイページに表示される最終更新時刻（運営返信／ユーザー追記で更新）
  lastActivityAt DateTime  @default(now()) @map("last_activity_at")
  /// RESOLVED 遷移時刻（180日経過で添付削除ジョブの判定に使用）
  resolvedAt     DateTime? @map("resolved_at")
  /// Wave6 Phase 9b-16: 担当オペレーター（SystemAdmin ユーザー）。null = 未割当
  assigneeUserId String?   @map("assignee_user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User?                 @relation("UserInquiries", fields: [userId], references: [id])
  category InquiryCategoryMaster @relation(fields: [categoryId], references: [id])
  assignee User?                 @relation("InquiryAssignee", fields: [assigneeUserId], references: [id])
  messages InquiryMessage[]

  @@index([userId, lastActivityAt(sort: Desc)])
  @@index([status, lastActivityAt(sort: Desc)])
  @@index([categoryId])
  @@index([assigneeUserId, status])

  @@map("inquiries")
  @@schema("support")
}

/// 問い合わせスレッド内の個別メッセージ（初回送信＋運営返信＋ユーザー追記）
model InquiryMessage {
  id           String   @id @default(uuid()) @map("id")
  inquiryId    String   @map("inquiry_id")
  /// 'USER' | 'OPERATOR' — 投稿者種別
  authorType   String   @map("author_type")
  /// authorType=OPERATOR の場合の運営担当者ユーザー ID。匿名や USER 投稿は null
  authorUserId String?  @map("author_user_id")
  body         String   @map("body") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  inquiry     Inquiry             @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  attachments InquiryAttachment[]

  @@index([inquiryId, createdAt])
  @@index([authorUserId])

  @@map("inquiry_messages")
  @@schema("support")
}

/// 問い合わせメッセージへの添付（画像/動画/PDF/テキスト）
model InquiryAttachment {
  id         String    @id @default(uuid()) @map("id")
  messageId  String    @map("message_id")
  storageKey String    @unique @map("storage_key")
  fileName   String    @map("file_name") @db.VarChar(255)
  mimeType   String    @map("mime_type") @db.VarChar(100)
  sizeBytes  Int       @map("size_bytes")
  /// 'PENDING' | 'CLEAN' | 'INFECTED' | 'ERROR'
  scanStatus String    @default("PENDING") @map("scan_status")
  scannedAt  DateTime? @map("scanned_at")
  /// RESOLVED 後の保持期間ジョブで S3 から削除されたかどうか（メタは残す）
  isPurged   Boolean   @default(false) @map("is_purged")
  purgedAt   DateTime? @map("purged_at")

  createdAt DateTime @default(now()) @map("created_at")

  message InquiryMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([scanStatus])
  @@index([isPurged])

  @@map("inquiry_attachments")
  @@schema("support")
}

/// Phase 7 / 9b-01: ヘルプ記事フィードバック（役立った/役立たなかった）
/// 認証ユーザーは [userId, articleSlug] で一意（再投票は upsert で上書き）。
/// 匿名（userId=null）は upsert できないため、複数行が積まれる（IP rate-limit で抑制）。
model HelpFeedback {
  id           String  @id @default(uuid()) @map("id")
  /// ヘルプ記事のslug
  articleSlug  String  @map("article_slug") @db.VarChar(200)
  /// カテゴリslug（集計時のドメイン軸グルーピング用、9b-04 で使用）
  categorySlug String  @map("category_slug") @db.VarChar(100)
  /// 認証ユーザーの場合のみ。匿名フィードバックは null
  userId       String? @map("user_id")
  /// true=役立った / false=役立たなかった
  helpful      Boolean @map("helpful")
  /// 任意フリーテキスト（最大500字）
  comment      String? @map("comment") @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, articleSlug])
  @@index([articleSlug, createdAt])
  @@index([categorySlug, createdAt])
  @@index([userId, createdAt])

  @@map("help_feedbacks")
  @@schema("support")
}
