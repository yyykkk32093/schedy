generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["activity", "announcement", "auth", "billing", "community", "identity", "master", "media", "messaging", "notification", "outbox", "support"]
}

// ---- OutboxEvent テーブル定義 ----

model OutboxEvent {
  id             String    @id @map("id")
  idempotencyKey String    @unique @map("idempotency_key")
  aggregateId    String    @map("aggregate_id")
  eventName      String    @map("event_name")
  eventType      String    @map("event_type")
  routingKey     String    @map("routing_key")
  payload        Json      @map("payload")
  occurredAt     DateTime  @map("occurred_at")
  publishedAt    DateTime? @map("published_at")
  status         String    @default("PENDING") @map("status")

  retryCount  Int      @default(0) @map("retry_count")
  nextRetryAt DateTime @default(now()) @map("next_retry_at")

  @@index([status, nextRetryAt])

  @@map("outbox_events")
  @@schema("outbox")
}

model OutboxRetryPolicy {
  routingKey   String @id @map("routing_key") // Handler に対応する routingKey
  maxRetries   Int    @default(5) @map("max_retries") // 最大リトライ回数
  baseInterval Int    @default(3000) @map("base_interval") // 初期インターバル（ms）
  maxInterval  Int    @default(60000) @map("max_interval") // インターバル上限（ms）

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("outbox_retry_policies")
  @@schema("outbox")
}

model AuthAuditLog {
  id         String   @id @default(uuid()) @map("id")
  action     String   @map("action") // auth.login.success | auth.login.failed | user.registered
  userId     String   @map("user_id")
  authMethod String   @map("auth_method")
  detail     String?  @map("detail")
  occurredAt DateTime @map("occurred_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, occurredAt])

  @@map("auth_audit_logs")
  @@schema("auth")
}

model OutboxDeadLetter {
  id String @id @default(uuid()) @map("id")

  outboxEventId String @map("outbox_event_id")
  routingKey    String @map("routing_key")
  eventType     String @map("event_type")

  payload        Json    @map("payload")
  errorMessage   String? @map("error_message")
  errorStack     String? @map("error_stack")
  errorType      String  @map("error_type") // IntegrationError.errorType (e.g. HANDLER_NOT_FOUND, HTTP_CLIENT_ERROR)
  retryCount     Int     @default(0) @map("retry_count")
  lastHttpStatus Int?    @map("last_http_status") // HttpIntegrationError の statusCode（該当しない場合 null）

  occurredAt DateTime @map("occurred_at") // 元イベントの発生時刻
  failedAt   DateTime @default(now()) @map("failed_at")

  @@index([failedAt])
  @@index([routingKey])

  @@map("outbox_dead_letters")
  @@schema("outbox")
}

model Activity {
  id                      String    @id @default(uuid()) @map("id")
  communityId             String    @map("community_id")
  title                   String    @map("title")
  description             String?   @map("description")
  defaultPlaceId          String?   @map("default_place_id") // 候補マスタ参照（Place）。defaultLocationCustom と XOR
  defaultLocationCustom   String?   @map("default_location_custom") // 自由入力（候補不一致時）。defaultPlaceId と XOR
  isOnline                Boolean   @default(false) @map("is_online") // オンライン開催フラグ。true 時は会場情報なし
  defaultStartTime        String?   @map("default_start_time") // "HH:mm" format
  defaultEndTime          String?   @map("default_end_time") // "HH:mm" format
  defaultParticipationFee Int?      @map("default_participation_fee") // デフォルト参加費（繰り返し生成時に引き継ぎ）
  defaultVisitorFee       Int?      @map("default_visitor_fee") // デフォルトビジター費（繰り返し生成時に引き継ぎ）
  defaultCapacity         Int?      @map("default_capacity") // デフォルト定員（繰り返し生成時に引き継ぎ）
  allowVisitorWaitlist    Boolean   @default(false) @map("allow_visitor_waitlist") // ビジターのキャンセル待ち参加を許可
  visibility              String    @default("PRIVATE") @map("visibility") // 'PUBLIC' | 'PRIVATE' — Wave6 W6-04: アクティビティ公開範囲
  recurrenceRule          String?   @map("recurrence_rule") // null in Phase 1
  organizerUserId         String?   @map("organizer_user_id") // 幹事ユーザーID（null = 未定）
  createdBy               String    @map("created_by")
  deletedAt               DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  community     Community      @relation(fields: [communityId], references: [id])
  defaultPlace  PlaceMaster?   @relation(fields: [defaultPlaceId], references: [id])
  schedules     Schedule[]
  chatChannel   ChatChannel?
  announcements Announcement[] // Phase3 #4: アクティビティ由来のお知らせ

  @@index([communityId])
  @@index([createdBy])
  @@index([organizerUserId])
  @@index([defaultPlaceId])

  @@map("activities")
  @@schema("activity")
}

// Wave6 Phase6 W6-07: 開催場所マスタ（OSM由来）
// - source/sourceId で OSM の安定IDを保持し再取得時のupsertキーとする
// - normalizedName/normalizedAddress に pg_trgm GIN インデックスを付与（migration内 raw SQL）
// - usageCount は Activity 保存時にインクリメント
model PlaceMaster {
  id                String  @id @default(uuid()) @map("id")
  name              String  @map("name") @db.VarChar(200)
  address           String  @map("address") @db.VarChar(500)
  lat               Float   @map("lat")
  lng               Float   @map("lng")
  normalizedName    String  @map("normalized_name") @db.VarChar(200) // 検索用正規化名（小文字・記号除去）
  normalizedAddress String  @map("normalized_address") @db.VarChar(500) // 検索用正規化住所
  category          String? @map("category") @db.VarChar(50) // OSM由来カテゴリ（sports_centre / community_centre 等）
  source            String  @map("source") @db.VarChar(20) // 'osm' 等
  sourceId          String  @map("source_id") @db.VarChar(100) // 'osm:node:123456' / 'osm:way:...' 形式の安定ID
  usageCount        Int     @default(0) @map("usage_count")
  isActive          Boolean @default(true) @map("is_active") // false = 最新スナップショットから消えた等で論理削除

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  activities Activity[]

  @@unique([source, sourceId])
  @@index([isActive, usageCount(sort: Desc)])

  @@map("place_masters")
  @@schema("master")
}

model Schedule {
  id               String    @id @default(uuid()) @map("id")
  activityId       String    @map("activity_id")
  date             DateTime  @map("date") @db.Date
  startTime        String    @map("start_time") // "HH:mm" format
  endTime          String    @map("end_time") // "HH:mm" format
  location         String?   @map("location")
  note             String?   @map("note")
  status           String    @default("SCHEDULED") @map("status") // SCHEDULED | CANCELLED
  capacity         Int?      @map("capacity")
  participationFee Int       @default(0) @map("participation_fee") // 参加費（円）。0 = 無料
  visitorFee       Int?      @map("visitor_fee") // ビジター参加費（null = 通常参加費と同額）
  isOnline         Boolean   @default(false) @map("is_online")
  meetingUrl       String?   @map("meeting_url") // オンライン時の会議URL
  visibility       String?   @map("visibility") // null = Activity を継承 / 'PUBLIC' | 'PRIVATE' — Wave6 W6-04: スケジュール個別の公開範囲オーバーライド
  deletedAt        DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  activity               Activity                @relation(fields: [activityId], references: [id])
  participations         Participation[]
  waitlistEntries        WaitlistEntry[]
  participationAuditLogs ParticipationAuditLog[]
  payments               Payment[]
  matchingResult         MatchingResult?

  @@index([activityId])
  @@index([date])

  @@map("schedules")
  @@schema("activity")
}

model Participation {
  id           String   @id @default(uuid()) @map("id")
  scheduleId   String   @map("schedule_id")
  userId       String?  @map("user_id") // 登録済みユーザーの場合はユーザーID。未登録ビジターの場合はnull
  isVisitor    Boolean  @default(false) @map("is_visitor")
  visitorName  String?  @map("visitor_name") @db.VarChar(50) // 未登録ビジターの表示名（isVisitor=true & userId=null 時に必須）
  visitorLevel Int?     @map("visitor_level") // ビジターの競技レベル（0-8）。null の場合はコミュニティ平均を適用
  addedBy      String?  @map("added_by") // ビジター追加者のユーザーID
  respondedAt  DateTime @default(now()) @map("responded_at")

  schedule Schedule  @relation(fields: [scheduleId], references: [id])
  payments Payment[] // Payment との1:N関連（通常1:1だが返金等で複数の可能性）

  // userId が NOT NULL の場合のみユニーク制約（部分インデックスはマイグレーションSQLで手動定義）
  @@index([scheduleId])
  @@index([userId])

  @@map("participations")
  @@schema("activity")
}

// 決済テーブル — Participation とは独立したライフサイクルを持つ
// キャンセル後も Payment レコードは残り、返金ステータスを追跡できる
model Payment {
  id                    String    @id @default(uuid()) @map("id")
  scheduleId            String    @map("schedule_id")
  participationId       String?   @map("participation_id") // Participation との紐付け（未登録ビジター含む全参加者を確実に辿れる）
  userId                String?   @map("user_id") // 登録済みユーザーの場合のみ設定（高速参照用の補助カラム）
  paymentMethod         String?   @map("payment_method") // CASH | PAYPAY | CREDIT_CARD | null（未決定=ビジター初期状態「ー」）
  displayName           String?   @map("display_name") @db.VarChar(100) // 支払い時点の表示名スナップショット（登録ユーザー=displayName, ビジター=visitorName）
  amount                Int       @map("amount") // 参加費
  feeAmount             Int       @default(0) @map("fee_amount") // プラットフォーム手数料
  status                String    @default("UNPAID") @map("status") // UNPAID | REPORTED | CONFIRMED | REJECTED | REFUND_PENDING | REFUNDED | NO_REFUND
  stripePaymentIntentId String?   @map("stripe_payment_intent_id")
  paymentReportedAt     DateTime? @map("payment_reported_at")
  paymentConfirmedAt    DateTime? @map("payment_confirmed_at")
  paymentConfirmedBy    String?   @map("payment_confirmed_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  schedule      Schedule       @relation(fields: [scheduleId], references: [id])
  participation Participation? @relation(fields: [participationId], references: [id])

  @@index([scheduleId, userId])
  @@index([participationId])
  @@index([stripePaymentIntentId])

  @@map("payments")
  @@schema("billing")
}

model WaitlistEntry {
  id           String   @id @default(uuid()) @map("id")
  scheduleId   String   @map("schedule_id")
  userId       String?  @map("user_id")
  isVisitor    Boolean  @default(false) @map("is_visitor")
  visitorName  String?  @map("visitor_name")
  addedBy      String?  @map("added_by")
  registeredAt DateTime @default(now()) @map("registered_at")

  schedule Schedule @relation(fields: [scheduleId], references: [id])

  // userId が NOT NULL の場合のみユニーク制約（部分インデックスはマイグレーションSQLで手動定義）
  @@index([scheduleId, userId])
  @@index([scheduleId, registeredAt])

  @@map("waitlist_entries")
  @@schema("activity")
}

model User {
  id                  String    @id @default(uuid()) @map("id")
  displayName         String?   @map("display_name")
  plan                String    @default("FREE") @map("plan")
  /// プラットフォーム（運営側）権限。テナント内の CommunityMembership.role とは別概念。
  /// 'USER' | 'OPERATOR' | 'SUPER_ADMIN'
  /// USER: 一般利用者 / OPERATOR: 運営オペレーター（問い合わせ対応・ヘルプ管理）/ SUPER_ADMIN: 全権
  systemRole          String    @default("USER") @map("system_role")
  email               String?   @unique @map("email")
  phone               String?   @map("phone")
  avatarUrl           String?   @map("avatar_url")
  biography           String?   @map("biography")
  notificationSetting Json      @map("notification_setting")
  /// Wave6 Phase 9b-05: 表示言語（'ja' | 'en'）。null = 未設定（クライアントが localStorage / navigator.language で判定）
  locale              String?   @map("locale")
  deletedAt           DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  passwordCredential PasswordCredential?
  googleCredential   GoogleCredential?
  lineCredential     LineCredential?
  appleCredential    AppleCredential?

  authSecurityState AuthSecurityState?

  // Phase 2.5: 参加リクエスト
  communityJoinRequests CommunityJoinRequest[]

  // Chat: 送信メッセージ
  messages Message[] @relation("UserMessages")

  // Phase4: 収支機能
  expenses Expense[]

  // Wave4: 退会記録
  withdrawal UserWithdrawal?

  // W5-25: チャンネル既読状態
  channelReadStates ChannelReadState[]

  // Wave6 Phase 8-B: 問い合わせ（認証ユーザー側）
  inquiries Inquiry[] @relation("UserInquiries")

  // Wave6 Phase 9b-16: 問い合わせ担当（運営側）
  assignedInquiries Inquiry[] @relation("InquiryAssignee")

  // Wave6 Phase10: 組み合わせ結果
  matchingResults MatchingResult[]

  @@map("users")
  @@schema("identity")
}

// ============================================================
// UserWithdrawal（Wave4: 退会理由記録）
// ============================================================

model UserWithdrawal {
  id       String  @id @default(uuid()) @map("id")
  userId   String  @unique @map("user_id")
  reason   String  @map("reason") // 'NOT_USING' | 'FOUND_ALTERNATIVE' | 'HARD_TO_USE' | 'FEE_TOO_HIGH' | 'OTHER'
  freeText String? @map("free_text")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_withdrawals")
  @@schema("auth")
}

model AuthSecurityState {
  userId String @id @map("user_id")

  /**
   * 最後に成功した認証方式（例: password/google/line/apple）
   */
  authMethod String? @map("auth_method")

  /**
   * 最終ログイン成功時刻（結果整合の投影）
   */
  lastLoginAt DateTime? @map("last_login_at")

  /**
   * セキュリティ判定向け（最小）
   */
  failedSignInCount Int       @default(0) @map("failed_sign_in_count")
  lockedUntil       DateTime? @map("locked_until")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lockedUntil])

  @@map("auth_security_states")
  @@schema("auth")
}

model PasswordCredential {
  userId         String   @id @map("user_id")
  hashedPassword String   @map("hashed_password")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_credentials")
  @@schema("auth")
}

model GoogleCredential {
  userId    String   @unique @map("user_id")
  googleUid String   @unique @map("google_uid")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("google_credentials")
  @@schema("auth")
}

model LineCredential {
  userId    String   @unique @map("user_id")
  lineUid   String   @unique @map("line_uid")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("line_credentials")
  @@schema("auth")
}

model AppleCredential {
  userId    String   @unique @map("user_id")
  appleUid  String   @unique @map("apple_uid")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("apple_credentials")
  @@schema("auth")
}

// ---- Community ----

model Community {
  id          String    @id @default(uuid()) @map("id")
  name        String    @map("name")
  description String?   @map("description")
  logoUrl     String?   @map("logo_url")
  coverUrl    String?   @map("cover_url")
  parentId    String?   @map("parent_id")
  depth       Int       @default(0) @map("depth")
  grade       String    @default("FREE") @map("grade") // 'FREE' | 'PREMIUM'
  createdBy   String    @map("created_by")
  deletedAt   DateTime? @map("deleted_at")

  // ---- Phase 2: Community Profile Fields ----
  joinMethod          String   @default("FREE_JOIN") @map("join_method") // 'FREE_JOIN' | 'APPROVAL' | 'INVITATION'
  isPublic            Boolean  @default(true) @map("is_public")
  maxMembers          Int?     @map("max_members")
  activityFrequency   String?  @map("activity_frequency")
  targetGender        String[] @default([]) @map("target_gender") // GenderTarget VO で型安全を担保
  ageMin              Int?     @map("age_min") // Wave5: 対象年齢下限（0-130）
  ageMax              Int?     @map("age_max") // Wave5: 対象年齢上限（0-130）
  recommendedLevelMin Int?     @map("recommended_level_min") // Wave5: 推奨レベル下限（0-8スケール）
  recommendedLevelMax Int?     @map("recommended_level_max") // Wave5: 推奨レベル上限（0-8スケール）

  // UBL-8: Payment settings
  payPayId              String?  @map("pay_pay_id")
  enabledPaymentMethods String[] @default(["CASH"]) @map("enabled_payment_methods")
  stripeAccountId       String?  @map("stripe_account_id") // Stripe Connect アカウントID（Destination Charges 用）

  // Phase 3: Community Notification Settings
  reminderEnabled          Boolean @default(true) @map("reminder_enabled") // スケジュール/支払いリマインダーを送信するか
  cancellationAlertEnabled Boolean @default(true) @map("cancellation_alert_enabled") // 当日キャンセル時に管理者にアラートを送信するか

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent   Community?  @relation("CommunityHierarchy", fields: [parentId], references: [id])
  children Community[] @relation("CommunityHierarchy")

  memberships   CommunityMembership[]
  activities    Activity[]
  announcements Announcement[]
  chatChannel   ChatChannel?
  albums        Album[]

  // Phase 2: 正規化リレーション
  categories          CommunityCategory[]
  participationLevels CommunityParticipationLevel[]
  activityDays        CommunityActivityDay[]
  tags                CommunityTag[]

  // Phase 2.5: 参加リクエスト
  joinRequests CommunityJoinRequest[]

  // UBL-34: 投票
  polls Poll[]

  // UBL-29: Webhook 連携
  webhookConfigs CommunityWebhookConfig[]

  // Phase3 #53: コミュニティブックマーク
  bookmarks CommunityBookmark[]

  // Phase4: 収支機能
  expenses          Expense[]
  expenseCategories ExpenseCategory[]

  // Wave4: 拠点管理
  locations CommunityLocation[]

  @@index([createdBy])
  @@index([parentId])

  @@map("communities")
  @@schema("community")
}

model CommunityMembership {
  id          String    @id @default(uuid()) @map("id")
  communityId String    @map("community_id")
  userId      String    @map("user_id")
  role        String    @default("MEMBER") @map("role") // 'OWNER' | 'ADMIN' | 'MEMBER'
  level       Int?      @map("level") // メンバーのコミュニティ内レベル（0-8）
  joinedAt    DateTime  @default(now()) @map("joined_at")
  leftAt      DateTime? @map("left_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([userId])

  @@map("community_memberships")
  @@schema("community")
}

// ============================================================
// CommunityLocation（Wave4: 複数拠点管理）
// ============================================================

model CommunityLocation {
  id          String  @id @default(uuid()) @map("id")
  communityId String  @map("community_id")
  type        String  @map("type") // 'MAIN' | 'SUB'
  area        String  @map("area") // 活動エリア名（例: 「渋谷」「新宿」）
  station     String? @map("station") // 最寄り駅（任意）
  sortOrder   Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId])

  @@map("community_locations")
  @@schema("community")
}

// ============================================================
// CommunityJoinRequest（Phase 2.5: 承認制参加リクエスト）
// ============================================================

model CommunityJoinRequest {
  id          String    @id @default(uuid()) @map("id")
  communityId String    @map("community_id")
  userId      String    @map("user_id")
  status      String    @default("PENDING") @map("status") // 'PENDING' | 'APPROVED' | 'REJECTED'
  message     String?   @map("message")
  reviewedBy  String?   @map("reviewed_by")
  reviewedAt  DateTime? @map("reviewed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@unique([communityId, userId, status])
  @@index([communityId])
  @@index([userId])

  @@map("community_join_requests")
  @@schema("community")
}

// ============================================================
// Announcement
// ============================================================

model Announcement {
  id          String    @id @default(uuid()) @map("id")
  communityId String    @map("community_id")
  authorId    String    @map("author_id")
  activityId  String?   @map("activity_id") // Phase3 #4: アクティビティ由来のお知らせ紐付け
  title       String    @map("title")
  content     String    @map("content")
  deletedAt   DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  community   Community                @relation(fields: [communityId], references: [id], onDelete: Cascade)
  activity    Activity?                @relation(fields: [activityId], references: [id], onDelete: SetNull)
  reads       AnnouncementRead[]
  likes       AnnouncementLike[]
  comments    AnnouncementComment[]
  attachments AnnouncementAttachment[]
  bookmarks   AnnouncementBookmark[]
  polls       Poll[]

  @@index([communityId])
  @@index([authorId])
  @@index([activityId])

  @@map("announcements")
  @@schema("announcement")
}

model AnnouncementRead {
  id             String   @id @default(uuid()) @map("id")
  announcementId String   @map("announcement_id")
  userId         String   @map("user_id")
  readAt         DateTime @default(now()) @map("read_at")

